# Google Gemini API key (required)
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini model (optional — defaults to gemini-2.5-flash-preview-04-17)
# Options: gemini-2.5-pro-preview-05-06, gemini-2.5-flash-preview-04-17, gemini-2.0-flash
# GEMINI_MODEL=gemini-2.5-flash-preview-04-17

# PIN for team login (change this!)
APP_PIN=change-me

# Session secret — required in production, must be a long random string
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=generate-a-strong-random-secret

# PostgreSQL (optional locally — app falls back to in-memory storage)
# DATABASE_URL=postgresql://user:pass@localhost:5432/trucksight
# DATABASE_SSL options:
#   (unset)    = strict TLS verification (production default)
#   no-verify  = skip cert verification (Render/Heroku managed DBs)
#   false      = disable SSL entirely (local dev only)
# DATABASE_SSL=no-verify

# Port
PORT=10000
