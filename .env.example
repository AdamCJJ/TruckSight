# Anthropic API key (required)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# OpenAI API key (optional — enables dual-LLM cross-validation)
# If set, estimates will run through both Claude AND GPT-4o for higher accuracy
OPENAI_API_KEY=sk-your-openai-key-here

# Google API key (optional — enables Gemini cross-validation)
# If set, estimates will also run through Gemini for multi-model accuracy
GOOGLE_API_KEY=your-google-api-key-here

# Gemini model to use (optional, defaults to gemini-2.5-flash)
# Options: gemini-2.5-flash (faster/cheaper) or gemini-2.5-pro (most accurate)
# GEMINI_MODEL=gemini-2.5-flash

# PIN for team login (change this!)
APP_PIN=1234

# Session secret (auto-generated on Render)
SESSION_SECRET=change-me-in-production

# PostgreSQL (optional locally — app falls back to in-memory storage)
# DATABASE_URL=postgresql://user:pass@localhost:5432/trucksight
# DATABASE_SSL=false

# Port
PORT=10000
